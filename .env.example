# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Admin User IDs (comma-separated) - Can report for free
ADMIN_IDS=123456789,987654321

# Owner IDs (comma-separated) - Can manage tokens and settings
OWNER_IDS=123456789

# Super Admin ID (full access to everything)
SUPER_ADMIN_ID=123456789

# Report Channel ID (where reports will be forwarded)
REPORT_CHANNEL_ID=-1001234567890

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
DATABASE_NAME=telegram_report_bot

# Encryption Key for sensitive data (generate with: python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())")
ENCRYPTION_KEY=your_32_byte_base64_encryption_key_here

# Token System Settings
TOKEN_PRICE_STARS=50
TOKEN_PRICE_INR=50
REPORT_COST_IN_TOKENS=1
FREE_REPORTS_FOR_NEW_USERS=0

# UPI Payment Details
UPI_ID=your-upi-id@okhdfcbank
PAYEE_NAME=Your Business Name

# Contact Information
ADMIN_USERNAME=your_admin_username
OWNER_USERNAME=your_owner_username
SUPPORT_GROUP=https://t.me/your_support_group
CHANNEL_LINK=https://t.me/your_channel
CONTACT_EMAIL=support@yourdomain.com

# Account Management Settings
MAX_ACCOUNTS_PER_USER=5
SESSION_TIMEOUT=3600

# Bot Settings
MAX_REPORT_LENGTH=1000
REPORT_COOLDOWN=30
REPORTS_PER_PAGE=10

# Optional: Telegram API credentials (for actual account login)
# Get from https://my.telegram.org/apps
API_ID=123456
API_HASH=your_api_hash_here